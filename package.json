{
  "name": "@arvoretech/bug-jar",
  "version": "0.3.0",
  "description": "Capture everything for non-technical people to help debug. One script tag, zero config.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "browser": "dist/index.global.js",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts --format cjs,esm,iife --global-name BugJar --dts --minify",
    "preview": "vite preview"
  },
  "keywords": [
    "bug-report",
    "debug",
    "network-capture",
    "error-tracking",
    "session-replay",
    "non-technical",
    "support-tool"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArvoreEducacao/bug-jar.git"
  },
  "packageManager": "pnpm@10.28.1",
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
